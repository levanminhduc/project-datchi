{
  "name": "quasar-project",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --fix",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "e2e:headed": "npx playwright test --headed",
    "server": "npx tsx server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "db:backup": "bash scripts/db-backup.sh",
    "db:restore": "bash scripts/db-restore.sh",
    "db:volume-backup": "bash scripts/db-volume-backup.sh",
    "db:seed": "psql -h 127.0.0.1 -p 54322 -U postgres -d postgres -f supabase/seed/master-data-seed.sql",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/roboto": "5.2.7",
    "@hono/node-server": "^1.19.9",
    "@quasar/extras": "^1.16.15",
    "@supabase/supabase-js": "^2.91.1",
    "@tiptap/extension-image": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/extension-table": "^3.21.0",
    "@tiptap/extension-table-cell": "^3.21.0",
    "@tiptap/extension-table-header": "^3.21.0",
    "@tiptap/extension-table-row": "^3.21.0",
    "@tiptap/extension-text-align": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "@tiptap/vue-3": "^3.21.0",
    "@vueuse/core": "^14.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "echarts": "^6.0.0",
    "exceljs": "^4.4.0",
    "hono": "^4.11.5",
    "isomorphic-dompurify": "^3.11.0",
    "jose": "^6.1.3",
    "jszip": "^3.10.1",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "quasar": "^2.17.10",
    "sharp": "^0.34.5",
    "vue": "^3.5.21",
    "vue-easy-lightbox": "^1.19.0",
    "vue-echarts": "^8.0.1",
    "vue-qrcode-reader": "^5.7.3",
    "vue-router": "^4.5.1",
    "vuedraggable": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.58.2",
    "@quasar/vite-plugin": "^1.11.0",
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^22.9.0",
    "@types/qrcode": "^1.5.6",
    "@types/sharp": "^0.31.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/language-server": "^3.2.5",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.35.0",
    "eslint-plugin-vue": "^10.0.0",
    "husky": "^9.1.7",
    "npm-run-all2": "^8.0.4",
    "sass": "^1.92.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.32.0",
    "unplugin-fonts": "^1.4.0",
    "unplugin-vue-components": "^31.0.0",
    "unplugin-vue-router": "^0.19.2",
    "vite": "^8.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.0"
