# ============================================
# Đất Chỉ - Docker Environment Variables
# Copy file này thành .env.docker rồi điền giá trị
# ============================================

# ── Ports ──────────────────────────────────
FRONTEND_PORT=8080
BACKEND_PORT=3010

# ── Image version (mặc định: latest) ──────
# IMAGE_TAG=latest
# IMAGE_TAG=v1.0.0

# ── Frontend URL (để backend CORS cho phép) ─
FRONTEND_URL=http://localhost:8080

# ── Supabase ───────────────────────────────
# Chạy `supabase status` trên máy để lấy các giá trị này
SUPABASE_HOST=host.docker.internal
SUPABASE_API_PORT=55421
ANON_KEY=your-supabase-anon-key
SERVICE_ROLE_KEY=your-service-role-key
JWT_SECRET=your-jwt-secret

# ── Telegram Bot (tùy chọn) ───────────────
TELEGRAM_BOT_TOKEN=
